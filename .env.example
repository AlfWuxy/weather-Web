# ============================================
# 环境变量配置示例（请复制为 .env 并填入真实值）
# ============================================

# Flask 密钥（必需，生产环境必须设置，>=32位，避免 dev/test/secret 等弱关键词）
# 生成方式：python3 -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=change-me-min-32-chars

# 配对令牌加密密钥（必需，生产环境必须设置）
# 生成方式：python3 -c 'import secrets; print(secrets.token_hex(32))'
PAIR_TOKEN_PEPPER=change-me-min-32-chars

# 数据库配置（可选，默认使用 instance/health_weather.db）
# 注意：Flask-SQLAlchemy 会把 sqlite 相对路径放在 instance_path 下。
# 因此如要使用 instance/health_weather.db，请配置为 sqlite:///health_weather.db（不要写 instance/ 前缀）。
DATABASE_URI=sqlite:///health_weather.db

# 和风天气API配置（可选，未配置时使用 Open-Meteo / 阈值规则兜底）
# 推荐 JWT。私钥必须放在仓库外，且文件权限为 0600；不要把真实 Host、私钥或令牌写回仓库。
QWEATHER_AUTH_MODE=disabled
QWEATHER_API_BASE=
# JWT 模式：QWEATHER_AUTH_MODE=jwt
QWEATHER_JWT_KID=
QWEATHER_JWT_PROJECT_ID=
QWEATHER_JWT_PRIVATE_KEY_PATH=
# 人工回滚模式：QWEATHER_AUTH_MODE=api_key。单次请求只会发送一种认证头。
QWEATHER_KEY=
# 本项目只使用都昌县县级天气；所有村庄共享这一份天气缓存。
QWEATHER_CANONICAL_LOCATION=116.20,29.27
QWEATHER_MONTHLY_REQUEST_LIMIT=40000
QWEATHER_BUDGET_FAIL_CLOSED=1
# 正式 QWeather 固定为 1；启用 api_key/jwt 时必须同时配置持久化 Redis。
# Redis 必须启用 AOF，appendfsync 只能使用 everysec 或 always；探测权限不足会关闭发布。
QWEATHER_REQUIRE_PERSISTENT_BUDGET=1
# 正式首发前从 QWeather 控制台人工读取一次。发布脚本只会把 Redis 计数提高到该基线，
# 并预留本次最多 3 个烟测端点及每 30 分钟最多 3 个端点直到下月起点。
QWEATHER_DEDICATED_CREDENTIAL_CONFIRMED=0
QWEATHER_CONSOLE_USAGE_MONTH=
QWEATHER_CONSOLE_USAGE_BASELINE=
# 和风天气网络应急闸门：留空立即放行；填写未来 Unix 秒会阻断至该时刻。
# 非空无效值会按关闭策略阻断，避免配置错误意外访问外网。
QWEATHER_NETWORK_NOT_BEFORE_EPOCH=
# 仅在明确接受“无天气快照”的预览发布时设为 1；正式上架保持 0。
ALLOW_WEATHER_UNAVAILABLE=0

# 高德地图API配置（推荐前后端分离，避免把 Web 服务 Key 用到前端）
# 前端地图 JS Key（会出现在浏览器请求里，请在高德后台做好域名绑定）
AMAP_JS_API_KEY=your-amap-js-api-key
# JS API 安全密钥（推荐走服务端代理，不在前端明文输出）
AMAP_SECURITY_JS_CODE=your-amap-security-code
# 后端 Web 服务 Key（只给服务端地理编码/查询使用，不要注入模板）
AMAP_WEB_SERVICE_KEY=your-amap-web-service-key
# 兼容旧配置：如果暂时还没拆分，也可只填 AMAP_KEY
# AMAP_KEY=your-legacy-amap-key

# 硅基流动AI配置（可选，未配置时AI问答不可用）
# 正式环境固定关闭；仅本地隔离实验可显式开启并配置官方端点。
FEATURE_WEB_AI=0
SILICONFLOW_API_KEY=
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# WxPusher（试点推送，子女端）
# 获取方式：WxPusher 后台创建应用，复制 appToken；用户在“个人设置”里填写 UID 并开启推送。
WXPUSHER_APP_TOKEN=
WXPUSHER_API_BASE=https://wxpusher.zjiecode.com/api
# 点击跟踪链接默认 7 天有效；可在 1 至 7 天内缩短，不允许延长披露期限。
PUSH_TRACKING_LINK_TTL_DAYS=7

# 微信小程序服务端登录。AppSecret 只能放在服务器环境变量，禁止写入 miniprogram/。
# 正式资料先写入被忽略的 .env.wechat-release，再由受控发布流程同步到服务器。
# AppID 必须与微信开发者工具正式工程一致；隐私版本必须与平台指引和小程序包一致。
WX_MINIPROGRAM_APPID=
WX_MINIPROGRAM_SECRET=
# 两项均使用独立的 32 字节以上随机值。
WX_MINIPROGRAM_OPENID_PEPPER=
WX_MINIPROGRAM_SESSION_SECRET=
# 更新隐私指引内容时同步递增版本，旧会话会要求重新同意。
WX_MINIPROGRAM_PRIVACY_VERSION=2026-07-18
# 默认会话 7 天，允许范围 5 分钟至 30 天。
WX_MINIPROGRAM_SESSION_TTL_SECONDS=604800
WX_MINIPROGRAM_MAX_ACTIVE_SESSIONS=5
WX_MINIPROGRAM_AUTH_TIMEOUT=8
# 逗号或空格分隔的内部测试账号 ID；只在服务端聚合报表中排除。
ANALYTICS_TEST_USER_IDS=
# 管理看板地区聚合的最小家庭数；生产环境最小值强制为 3，避免小样本地点识别。
ANALYTICS_MIN_LOCATION_COUNT=3
# 网页生成的兼容 Token 默认 30 天有效，历史无期限 Token 会被要求轮换。
API_TOKEN_TTL_DAYS=30

# 外部访问基址（用于推送点击追踪链接）
# 生产环境请填写 https://api.your-domain.com
PUBLIC_BASE_URL=
ALLOW_INSECURE_PUBLIC_BASE_URL=
RATE_LIMIT_AMAP_PROXY=30 per minute
RATE_LIMIT_MP_READ=120 per minute
RATE_LIMIT_MP_WRITE=30 per minute
RATE_LIMIT_MP_ALERTS=30 per minute
RATE_LIMIT_MP_EVENTS=60 per minute
RATE_LIMIT_MP_AUTH=10 per 5 minutes
RATE_LIMIT_MP_PUBLIC=600 per minute
# 每 30 分钟一条，默认保留约 48 小时。
MINIPROGRAM_SNAPSHOT_RETENTION=96
# 小程序 JSON 写请求上限 1 MiB，避免异常大包占用服务端内存。
MAX_CONTENT_LENGTH_BYTES=1048576
PAIR_ACTION_TOKEN_TTL_DAYS=90
SHORT_CODE_TTL_DAYS=90

# 默认城市配置
DEFAULT_CITY=都昌
DEFAULT_LOCATION=116.20,29.27

# 调试模式（生产环境必须设为 false）
DEBUG=false

# Redis（普通限流可选；QWEATHER_AUTH_MODE=api_key/jwt 时必填并满足上方 AOF 门禁）
# 例如：redis://localhost:6379/0
REDIS_URL=
# 如需单独指定天气缓存 Redis，可使用：
WEATHER_CACHE_REDIS_URL=

# 受信代理网段（仅这些 REMOTE_ADDR 才会被允许解析 X-Forwarded-For）
# 生产环境请按实际网关/负载均衡网络填写，例如：10.0.0.0/8,192.168.0.0/16
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# 速率限制配置
RATE_LIMITS=200 per minute
# 生产环境不要使用 memory://，应配置 Redis
RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0
RATE_LIMIT_LOGIN=5 per 5 minutes
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_SECONDS=300
RATE_LIMIT_SHORT_CODE=3 per hour

# AI 请求控制参数
AI_CONNECT_TIMEOUT=8
AI_READ_TIMEOUT=60
AI_REQUEST_RETRIES=1
AI_MAX_TOKENS=800

# 缓存 TTL（分钟）
WEATHER_CACHE_TTL_MINUTES=30
FORECAST_CACHE_TTL_MINUTES=30
QWEATHER_WARNING_CACHE_TTL_MINUTES=30
WEATHER_SYNC_LOCATIONS=都昌县
# 社区风险分析结果缓存（秒，略大于 20 分钟预热周期，避免空档）
COMMUNITY_RISK_CACHE_TTL_SECONDS=1500
# 社区风险缓存锁（秒，避免多人同时重复计算）
COMMUNITY_RISK_CACHE_LOCK_SECONDS=20
# 等待其他请求回填缓存的时间（秒）
COMMUNITY_RISK_CACHE_WAIT_SECONDS=1.2
# 地点解析缓存（天）
LOCATION_CACHE_TTL_DAYS=90

# 社区风险预热（默认每 20 分钟由 systemd timer 触发）
COMMUNITY_RISK_PRECOMPUTE_LOCATIONS=
COMMUNITY_RISK_PRECOMPUTE_WINDOW_DAYS=30
COMMUNITY_RISK_PRECOMPUTE_DISEASES=

# 演示模式（仅用于测试，生产环境设为 0）
DEMO_MODE=0

# 都昌县 1 km 热暴露 GIS。普通预览默认关闭；微信全功能正式发布表单会强制设为 1。
# 紧急回滚时可设为 0 并重启应用，同时必须撤下对应功能声明。
FEATURE_HEAT_EXPOSURE_GIS=0

# Sentry 监控（可选）
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_SEND_PII=0

# 部署配置（仅开发环境使用，生产环境不要配置）
# DEPLOY_SERVER=
# DEPLOY_USER=
# DEPLOY_PROJECT_DIR=
# DEPLOY_LOCAL_DIR=
# 微信正式发布表单单独创建，真实值不写入本文件或普通 .env：
# cp .env.wechat-release.example .env.wechat-release
# chmod 600 .env.wechat-release
# 表单内保持 WECHAT_CATEGORY_CONFIRMED=0，直到发布当天完成个人主体正式类目截图与人工复核。
# 运营者资料、AppID、AppSecret、隐私版本和类目全部核对后，最后设置 WECHAT_FORM_READY=1。
# WECHAT_RELEASE_FORM_FILE=/absolute/path/to/.env.wechat-release
# 正式上架发布设为 1；认证前的公开页面预览可保持 0。该开关会强制校验上述两个表单门禁。
# DEPLOY_REQUIRE_WECHAT_READY=0
# 只有人工核对 ROLLBACK_REQUIRED.txt 或 POST_COMMIT_ATTENTION.txt 对应的精确事务后才填写。
# DEPLOY_RECOVERY_ACKNOWLEDGED_TRANSACTION=/opt/your-app/backups/deploy-transactions/<exact-transaction>
