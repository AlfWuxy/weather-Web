# 微信小程序正式发布私密表单模板
# 复制为 .env.wechat-release 后执行：chmod 600 .env.wechat-release
# 真实表单已被 .gitignore 排除，严禁提交 AppSecret、证件或付款信息。

# 固定个人主体。若微信后台显示其他主体类型，请停止填写。
WECHAT_SUBJECT_TYPE=personal

# 以下资料由发布执行方在认证完成后，根据微信后台已验证信息填写。
# 名称审核通过前保持空白；通过后必须逐字填写后台批准名称并同步五份冻结材料。
WECHAT_MINIPROGRAM_NAME=
WECHAT_OPERATOR_NAME=
WECHAT_CONTACT_EMAIL=
WECHAT_EFFECTIVE_DATE=
# 微信后台 request 合法域名，必须与冻结 HEAD 的 miniprogram/config.runtime.js 一致。
WECHAT_REQUEST_DOMAIN=https://yilaoweather.org

# 只有实际确认个人主体可选类目且无需额外资质后，才改为 1。
WECHAT_CATEGORY_CONFIRMED=0

# 使用 JSON 字符串数组记录后台全部必要类目的完整路径，每条至少包含一级/二级。
WECHAT_CATEGORY_PATHS_JSON=
# 个人主体首发只允许填写：no_extra_institutional_qualification
WECHAT_CATEGORY_QUALIFICATION_STATUS=
# 填仓库外私有证据目录的绝对路径；目录及中间目录仅允许当前用户访问。
WECHAT_CATEGORY_EVIDENCE_ROOT=
# 填上述目录内的相对文件引用，禁止绝对路径、反斜杠和 .. 跳转。
WECHAT_CATEGORY_EVIDENCE_REF=
# 填证据文件逐字节 SHA-256；证据文件必须非空、权限为 0600 且不能是符号链接。
WECHAT_CATEGORY_EVIDENCE_SHA256=
# 填带时区的 ISO 8601 确认时间，例如：2026-07-18T15:30:00+08:00
WECHAT_CATEGORY_CONFIRMED_AT=

# 以下发布冻结字段只能由发布执行方在最终干净 commit 和文案定稿后计算。
# 首发版本当前固定为 1.0.0；所有 SHA 必须来自同一目标 commit，严禁提前填占位值。
WECHAT_RELEASE_VERSION=
WECHAT_TARGET_COMMIT_SHA=
# docs/miniprogram/PRIVACY_NOTICE_TEMPLATE.md
WECHAT_PRIVACY_DOC_SHA256=
# docs/miniprogram/USER_AGREEMENT_TEMPLATE.md
WECHAT_AGREEMENT_DOC_SHA256=
# docs/miniprogram/LISTING_COPY.md
WECHAT_LISTING_COPY_SHA256=
# miniprogram/pages/privacy/index.wxml
WECHAT_PRIVACY_PAGE_SHA256=
# miniprogram/pages/agreement/index.wxml
WECHAT_AGREEMENT_PAGE_SHA256=

# 用户认证后只需提供这两项，其余服务端密钥会在服务器内生成。
WX_MINIPROGRAM_APPID=
WX_MINIPROGRAM_SECRET=
WX_MINIPROGRAM_PRIVACY_VERSION=2026-07-18

# 为避免旧凭据当月历史用量被误当成 0，正式发布当天从 QWeather 控制台抄录一次。
# 凭据必须只供本项目使用；Project ID 与 KID 属于非敏感标识，必须逐字抄录并与 .env 匹配。
# 月份使用北京时间 YYYY-MM，已用量填控制台整数。
# 门禁会额外预留本次最多 3 个烟测端点及每 30 分钟最多 3 个端点直到下月起点。
QWEATHER_DEDICATED_CREDENTIAL_CONFIRMED=0
QWEATHER_EXPECTED_PROJECT_ID=
QWEATHER_EXPECTED_KID=
QWEATHER_CONSOLE_USAGE_MONTH=
QWEATHER_CONSOLE_USAGE_BASELINE=

# 1.0.0 首发固定关闭第三方推送，并显式启用热暴露 GIS。
# 发布脚本会在任何远端操作前，对冻结提交内 GIS 同时执行 gzip/Brotli 300 KiB 门禁。
# 首发时 WxPusher token 必须留空，避免收集 UID 或触发第三方请求。
FEATURE_WXPUSHER=0
WXPUSHER_APP_TOKEN=
FEATURE_HEAT_EXPOSURE_GIS=1

# 上述字段全部完成后最后改为 1，发布脚本会再次校验权限和完整性。
# 远程发布只接受 DEPLOY_REQUIRE_WECHAT_READY=1；0 只用于本地微信开发者工具预览。
WECHAT_FORM_READY=0
