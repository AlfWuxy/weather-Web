.page-shell {
  padding: 30rpx 28rpx calc(64rpx + env(safe-area-inset-bottom));
}

.page-title {
  color: #14251c;
  font-size: 42rpx;
  font-weight: 700;
}

.page-copy {
  margin-top: 10rpx;
  color: #66736c;
  font-size: 14px;
  line-height: 1.65;
}

.state-box,
.message-card,
.safety-card {
  margin-top: 26rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(25, 58, 39, 0.07);
}

.state-box {
  color: #66736c;
  text-align: center;
}

.weather-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid #e3ebe6;
}

.location {
  color: #176d40;
  font-size: 14.5px;
  font-weight: 700;
}

.weather-summary {
  color: #637168;
  font-size: 14px;
}

.weather-summary.stale {
  color: #784116;
}

.weather-notice {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #f1f4f2;
  color: #4f5f56;
  font-size: 14px;
  line-height: 1.6;
}

.weather-notice.stale {
  background: #fff4e5;
  color: #784116;
}

.message-text {
  margin-top: 24rpx;
  color: #21372b;
  font-size: 15px;
  line-height: 1.85;
  white-space: pre-wrap;
}

.copy-button,
.checkin-button {
  min-height: 90rpx;
  border-radius: 18rpx;
  font-size: 14.5px;
  font-weight: 600;
  line-height: 90rpx;
}

.copy-button {
  margin-top: 28rpx;
  background: #167a43;
  color: #ffffff;
}

.checkin-button {
  margin-top: 14rpx;
  border: 1rpx solid #cbd8d0;
  background: #ffffff;
  color: #315340;
}

.safety-card {
  background: #fff9ed;
  box-shadow: none;
}

.safety-title {
  color: #8c5a0a;
  font-size: 14px;
  font-weight: 700;
}

.safety-copy {
  margin-top: 10rpx;
  color: #6f5b35;
  font-size: 14px;
  line-height: 1.7;
}

.back-link {
  margin-top: 22rpx;
  background: transparent;
  color: #52645a;
  font-size: 14px;
}

.back-link::after {
  border: 0;
}
