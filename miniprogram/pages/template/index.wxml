<view style="padding: 16px;">
  <view class="card">
    <view style="font-size: 18px; font-weight: 700;">一键提醒话术</view>
    <view class="muted" style="margin-top: 6px; font-size: 12px;">
      你作为“可信节点”把行动建议转述给家人。话术为通用建议，不提供医疗诊断/治疗建议。
    </view>
  </view>

  <view style="height: 12px;"></view>

  <block wx:if="{{loading}}">
    <view class="muted" style="text-align:center; padding: 20px;">加载中…</view>
  </block>

  <block wx:if="{{!loading}}">
    <view class="card">
      <view class="muted" style="font-size: 12px;">地点：{{locationText}}</view>
      <view class="muted" style="font-size: 12px; margin-top: 4px;">
        Tmax {{tmax || '-'}} · Tmin {{tmin || '-'}}
      </view>
      <view style="margin-top: 12px; white-space: pre-wrap; line-height: 1.7;">{{message}}</view>
      <view style="display:flex; gap: 10px; margin-top: 14px;">
        <button class="btn-primary" style="flex:1;" bindtap="copyMessage">一键复制</button>
        <button class="btn-outline" style="flex:1;" bindtap="back">返回</button>
      </view>
    </view>
  </block>
</view>

