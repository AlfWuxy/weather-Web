<view class="page-shell">
  <view class="page-title">健康状态筛查</view>
  <view class="page-copy">5 项快速筛查，帮助家人决定今天要多留意什么。筛查不作医疗诊断。</view>

  <view wx:if="{{loading}}" class="state-box" role="status" aria-role="status" aria-live="polite">正在加载…</view>
  <view wx:elif="{{loadError}}" class="history-error" role="alert" aria-role="alert" aria-live="assertive">
    <view>{{loadError}}</view>
    <button class="history-retry" bindtap="loadPage">重新加载筛查页面</button>
    <button class="history-retry" bindtap="backToCare">返回家庭照护</button>
  </view>
  <block wx:elif="{{contextReady}}">
    <view class="person-card">
      <view>
        <view class="person-label">正在为谁筛查</view>
        <picker range="{{elderNames}}" value="{{elderIndex}}" bindchange="onElderChange" disabled="{{!contextReady || busy || loading}}" aria-label="选择要进行健康筛查的家人">
          <view class="person-picker"><text>{{elderNames[elderIndex]}}</text><image class="person-picker-icon" src="/assets/icons/chevron-right.png" mode="aspectFit" aria-hidden="true" /></view>
        </picker>
      </view>
      <view class="progress-text">{{completedCount}} / 5</view>
    </view>

    <block wx:for="{{questions}}" wx:key="id" wx:for-item="question">
      <view class="question-card">
        <view class="question-title"><text>{{question.number}}</text>{{question.title}}</view>
        <view class="option-list" role="radiogroup" aria-role="radiogroup" aria-label="{{question.title}}">
          <block wx:for="{{question.options}}" wx:key="value" wx:for-item="option">
            <button
              class="option-button {{option.active ? 'active' : ''}}"
              data-id="{{question.id}}"
              data-value="{{option.value}}"
              bindtap="onSelect"
              disabled="{{!contextReady || busy}}"
              role="radio"
              aria-role="radio"
              aria-checked="{{option.active}}"
              aria-label="{{option.label}}，{{option.active ? '已选择' : '未选择'}}"
            >
              <image wx:if="{{option.active}}" class="option-check" src="/assets/icons/check-white.png" mode="aspectFit" aria-hidden="true" />
              <text>{{option.label}}</text>
              <text wx:if="{{option.active}}" class="selected-label">已选</text>
            </button>
          </block>
        </view>
      </view>
    </block>

    <button class="submit-button" loading="{{busy}}" disabled="{{!contextReady || busy}}" bindtap="submitAssessment">提交本次筛查</button>

    <view wx:if="{{latestLoading && !latest}}" class="history-state" role="status" aria-role="status">正在读取最近一次筛查结果…</view>
    <view wx:if="{{latestError}}" class="history-error" role="status" aria-role="status" aria-live="polite">
      <view>{{latestError}}</view>
      <button class="history-retry" disabled="{{latestLoading}}" bindtap="loadLatest">{{latestLoading ? '正在重试…' : '重新读取最近结果'}}</button>
    </view>

    <view wx:if="{{latest}}" class="result-card" role="status" aria-role="status" aria-live="polite">
      <view class="result-label">最近一次筛查结果</view>
      <view class="result-level">{{latest.riskLevel}}</view>
      <view wx:if="{{latest.riskScore !== ''}}" class="result-score">参考分值 {{latest.riskScore}}</view>
      <view wx:if="{{latest.recommendations.length}}" class="recommend-title">今天可以这样做</view>
      <view wx:for="{{latest.recommendations}}" wx:key="*this" class="recommend-row">{{index + 1}}. {{item}}</view>
      <view class="result-note">结果只作行动参考。身体明显不适时，请及时联系家人并就医或求助。</view>
    </view>
  </block>
  <view wx:else class="state-box" role="status" aria-role="status">请返回家庭照护，重新选择需要筛查的家人。</view>
</view>
