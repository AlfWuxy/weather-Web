<view class="page-shell">
  <view class="hero alert-hero">
    <view class="hero-kicker">{{locationName}} · 官方预警</view>
    <view class="hero-title">先看预警，再决定今天怎么安排。</view>
    <view class="hero-subtitle">预警可能存在发布和同步延迟，请同时留意当地主管部门的最新通知。</view>
  </view>

  <status-card wx:if="{{loading}}" state="loading" title="正在读取预警" detail="30 分钟内会复用同一份天气快照。" />
  <status-card wx:elif="{{error && !current}}" state="error" title="预警暂不可用" detail="{{error}}" action-label="重试" bind:action="retry" />

  <block wx:if="{{current}}">
    <freshness-bar updated-text="{{freshness.updatedText}}" stale="{{freshness.stale}}" source="{{freshness.source}}" refresh-deferred="{{freshness.refreshDeferred}}" refresh-started="{{freshness.refreshStarted}}" />
    <view class="card weather-strip">
      <view><view class="small muted">{{freshness.stale ? '较早观测' : '当前'}}</view><view class="strip-value">{{current.temperatureText}}</view></view>
      <view><view class="small muted">最高</view><view class="strip-value">{{current.highText}}</view></view>
      <view><view class="small muted">最低</view><view class="strip-value">{{current.lowText}}</view></view>
    </view>

    <view class="section-title">{{freshness.stale ? '官方预警待刷新' : '有效预警'}}</view>
    <view wx:for="{{warnings}}" wx:key="id" class="warning-card card warning-{{item.tone}}">
      <view class="row-between">
        <view class="card-title warning-title">{{item.title}}</view>
        <view class="pill {{item.tone}}">{{item.level || item.type || '预警'}}</view>
      </view>
      <view wx:if="{{item.type}}" class="small muted warning-type">{{item.type}}</view>
      <view class="warning-text">{{item.text}}</view>
      <view class="small muted warning-meta">
        <view>发布单位：{{item.issuer || '未提供，请以当地主管部门通知为准'}}</view>
        <view>发布时间：{{item.issuedText}}</view>
        <view>生效时间：{{item.effectiveText}}</view>
        <view wx:if="{{item.expiresAt}}">结束时间：{{item.expiresText}}</view>
      </view>
    </view>
    <status-card wx:if="{{freshness.stale}}" state="error" title="官方预警有效性待核对" detail="缓存中的预警记录可能已经失效，刷新前不继续显示为有效预警。请同时查看当地主管部门的最新通知。" />
    <status-card wx:elif="{{!warningsSourceAvailable}}" state="error" title="官方预警来源暂不可用" detail="当前无法确认是否存在有效预警，请同时查看当地主管部门的最新通知。" />
    <status-card wx:elif="{{!warnings.length}}" state="empty" title="当前暂无官方预警" detail="没有官方预警仍可能出现高温、低温或空气质量风险，请继续查看今日风险和行动。" />

    <navigator class="primary-button" url="/pages/actions/index">查看今日行动</navigator>
    <view class="safe-note alert-note">如出现意识不清、呼吸困难、胸痛、抽搐等紧急情况，请立即拨打 120。预警页无法替代专业判断。</view>
  </block>
</view>
