<view class="page-shell">
  <view class="page-header">
    <view>
      <view class="page-title">家庭照护</view>
      <view class="page-subtitle">{{fixedLocation}} · 一份天气，多位家人共用</view>
    </view>
    <button class="header-button" bindtap="goSettings">设置</button>
  </view>

  <view class="weather-strip {{weather.trigger || 'normal'}}">
    <view>
      <view class="weather-label">都昌县今日天气</view>
      <view class="weather-value" wx:if="{{weather.available}}">
        {{weather.temperature === null ? '--' : weather.temperature}}°
        <text class="weather-range">最高 {{weather.temperatureMax === null ? '--' : weather.temperatureMax}}° · 最低 {{weather.temperatureMin === null ? '--' : weather.temperatureMin}}°</text>
      </view>
      <view class="weather-value weather-wait" wx:else>天气正在更新</view>
    </view>
    <view class="risk-badge" wx:if="{{weather.trigger === 'heat'}}">高温留意</view>
    <view class="risk-badge cold" wx:elif="{{weather.trigger === 'cold'}}">低温留意</view>
    <view class="risk-badge safe" wx:else>日常留意</view>
  </view>

  <button class="add-button" bindtap="goCreate">
    <image class="add-button-icon" src="/assets/icons/add-white.png" mode="aspectFit" aria-hidden="true" />
    <text>添加家中老人</text>
  </button>

  <view wx:if="{{loading && elders.length}}" class="inline-refresh" role="status" aria-role="status" aria-live="polite">正在刷新照护资料…</view>
  <view wx:if="{{loadError && elders.length}}" class="inline-warning" role="status" aria-role="status" aria-live="polite">
    <view>{{loadError}}</view>
    <button class="retry-button inline-retry" bindtap="loadCareHome">重新刷新</button>
  </view>

  <view wx:if="{{loading && !elders.length}}" class="state-box">正在加载照护资料…</view>
  <view wx:elif="{{loadError && !elders.length}}" class="state-box error-state">
    <view>{{loadError}}</view>
    <button class="retry-button" bindtap="loadCareHome">重新加载</button>
  </view>
  <view wx:elif="{{elders.length === 0}}" class="empty-card">
    <view class="empty-title">还没有添加家人</view>
    <view class="empty-copy">添加后可以一起查看预警、提醒话术、健康记录和今日行动。</view>
    <button class="primary-button empty-button" bindtap="goCreate">现在添加</button>
  </view>

  <block wx:for="{{elders}}" wx:key="pair_id">
    <view class="elder-card">
      <view class="elder-top">
        <view class="elder-avatar">{{item.initial}}</view>
        <view class="elder-main">
          <view class="elder-name">{{item.displayName}}</view>
          <view class="elder-meta">{{item.displayRelation}} · {{item.displayAge}} · 都昌县</view>
        </view>
        <button class="edit-button" data-pair-id="{{item.pair_id}}" bindtap="goEdit">编辑</button>
      </view>

      <view class="primary-actions">
        <button class="primary-action warning-action" data-pair-id="{{item.pair_id}}" bindtap="goAlerts">查看预警</button>
        <button class="primary-action" data-pair-id="{{item.pair_id}}" bindtap="goCheckin">今日行动</button>
        <button class="primary-action" data-pair-id="{{item.pair_id}}" bindtap="goTemplate">提醒话术</button>
      </view>

      <view class="care-tools">
        <button class="tool-button" data-pair-id="{{item.pair_id}}" bindtap="goAssessment">健康筛查</button>
        <button class="tool-button" data-pair-id="{{item.pair_id}}" bindtap="goDiary">健康日记</button>
        <button class="tool-button" data-pair-id="{{item.pair_id}}" bindtap="goMedications">用药记录</button>
      </view>

      <button class="delete-link" data-pair-id="{{item.pair_id}}" data-name="{{item.displayName}}" bindtap="deleteElder">停止管理这位老人</button>
    </view>
  </block>

  <view class="medical-note">健康功能用于行动筛查和日常记录，不作医疗诊断。若出现胸痛、呼吸困难、意识异常等严重症状，请及时就医或求助。</view>
</view>
