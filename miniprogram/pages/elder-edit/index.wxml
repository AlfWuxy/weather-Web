<view class="page-shell">
  <view class="page-title">{{mode === 'create' ? '添加家中老人' : '编辑老人资料'}}</view>
  <view class="page-copy">资料用于生成更合适的天气行动提醒。慢病只需填写类别。</view>

  <view wx:if="{{loading}}" class="loading-box">正在加载资料…</view>
  <view wx:else class="form-card">
    <view class="field-group">
      <view class="field-label">姓名或家中称呼 <text class="required">*</text></view>
      <input class="text-input" maxlength="50" value="{{name}}" bindinput="onName" placeholder="例如：妈妈、张奶奶" aria-label="姓名或家中称呼，必填" />
    </view>

    <view class="field-group">
      <view class="field-label">与你的关系</view>
      <input class="text-input" maxlength="20" value="{{relation}}" bindinput="onRelation" placeholder="例如：母亲、爷爷" aria-label="这位家人与你的关系" />
    </view>

    <view class="two-column">
      <view class="field-group column-field">
        <view class="field-label">年龄</view>
        <input class="text-input" type="number" maxlength="3" value="{{age}}" bindinput="onAge" placeholder="例如：68" aria-label="这位家人的年龄" />
      </view>
      <view class="field-group column-field">
        <view class="field-label">性别</view>
        <picker range="{{genderOptions}}" value="{{genderIndex}}" bindchange="onGender" aria-label="这位家人的性别">
          <view class="picker-field">{{gender}}</view>
        </picker>
      </view>
    </view>

    <view class="field-group">
      <view class="field-label">所在地区</view>
      <view class="fixed-field">都昌县 <text>已固定</text></view>
      <view class="field-hint">小程序当前天气与预警范围固定为都昌县。</view>
    </view>

    <view class="field-group">
      <view class="field-label">慢病类别</view>
      <textarea class="text-area" maxlength="300" value="{{chronicText}}" bindinput="onChronic" placeholder="例如：高血压、糖尿病。请勿填写病历号或身份证号。" aria-label="这位家人的慢病类别" />
    </view>

    <view class="button-row">
      <button class="primary-button row-button" loading="{{busy}}" disabled="{{busy}}" bindtap="onSave">{{mode === 'create' ? '确认添加' : '保存修改'}}</button>
      <button class="secondary-button row-button" disabled="{{busy}}" bindtap="onCancel">取消</button>
    </view>
  </view>
</view>
