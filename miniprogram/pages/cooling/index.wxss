.cooling-hero { background: linear-gradient(145deg, #9f3a12 0%, #b35924 100%); }
.filters { width: 100%; margin: 20rpx 0; white-space: nowrap; }
.filter-row { display: inline-flex; gap: 14rpx; padding: 2rpx; }
.filter-pill { display: inline-flex; align-items: center; justify-content: center; gap: 10rpx; min-height: 88rpx; margin: 0; padding: 14rpx 24rpx; border-radius: 999rpx; color: #685a51; background: #f3e8df; font-size: 14px; line-height: 1.4; }
.filter-pill.active { color: #fff; background: #b64815; }
.filter-icon { flex: 0 0 34rpx; width: 34rpx; height: 34rpx; }
.filter-state { font-size: 14px; font-weight: 700; }
.resource-name { flex: 1; min-width: 0; }
.community-label { margin-top: 8rpx; font-size: 14px; }
.resource-line { display: grid; grid-template-columns: 92rpx 1fr; gap: 14rpx; margin-top: 18rpx; font-size: 14px; line-height: 1.6; }
.line-label { color: #66594f; font-weight: 700; }
.tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 18rpx; }
.tag { padding: 7rpx 15rpx; border-radius: 999rpx; color: #276141; background: #e6f6ed; font-size: 14px; }
.resource-note { margin-top: 16rpx; padding: 16rpx; border-radius: 14rpx; background: #f8f2ed; font-size: 14px; }
.resource-actions { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14rpx; margin-top: 22rpx; }
.small-button { min-height: 88rpx; padding: 14rpx 18rpx; font-size: 14px; }
.safe-note { font-size: 14px; }
.empty-guidance { margin-top: 20rpx; }
.guidance-row { display: flex; align-items: flex-start; gap: 18rpx; margin-top: 20rpx; color: #5f5148; font-size: 15px; line-height: 1.6; }
.guidance-number { display: flex; flex: 0 0 52rpx; align-items: center; justify-content: center; width: 52rpx; height: 52rpx; border-radius: 50%; color: #fff; background: #b64815; font-size: 14px; font-weight: 800; }
.guidance-button { margin-top: 24rpx; }

@media screen and (max-width: 340px) {
  .resource-line,
  .resource-actions { grid-template-columns: 1fr; }
}
