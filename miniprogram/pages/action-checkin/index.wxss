.page-shell {
  padding: 30rpx 28rpx calc(70rpx + env(safe-area-inset-bottom));
}

.page-title {
  color: #14251c;
  font-size: 42rpx;
  font-weight: 700;
}

.page-copy {
  margin-top: 10rpx;
  color: #66736c;
  font-size: 14px;
  line-height: 1.65;
}

.state-box,
.weather-card,
.action-card,
.help-card,
.debrief-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(25, 58, 39, 0.07);
}

.state-box {
  color: #68766e;
  font-size: 16px;
  line-height: 1.65;
  text-align: center;
}

.error-state {
  border: 2rpx solid #efd6d1;
  background: #fff8f6;
  color: #6f332d;
}

.state-title {
  color: #6f2f28;
  font-size: 17px;
  font-weight: 700;
}

.state-copy {
  margin-top: 10rpx;
}

.retry-button {
  min-height: 88rpx;
  margin-top: 22rpx;
  border-radius: 16rpx;
  background: #167a43;
  color: #ffffff;
  font-size: 16px;
  font-weight: 700;
  line-height: 88rpx;
}

.weather-card {
  background: #edf7f1;
  box-shadow: none;
}

.weather-card.heat {
  background: #fff0e8;
}

.weather-card.cold {
  background: #eaf3ff;
}

.weather-card.pending {
  background: #f3f5f4;
}

.weather-card.stale {
  border: 2rpx solid #efc697;
  background: #fff4e5;
}

.weather-title {
  color: #26513a;
  font-size: 16px;
  font-weight: 700;
}

.weather-detail {
  margin-top: 8rpx;
  color: #5d6f65;
  font-size: 14px;
}

.section-title {
  margin: 0;
  color: #243c2f;
  font-size: 16px;
  font-weight: 700;
}

.danger-title {
  color: #8e2f27;
  font-size: 16px;
}

.action-row {
  display: flex;
  align-items: flex-start;
  min-height: 92rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #e3eae6;
}

.action-copy {
  flex: 1;
  margin-left: 14rpx;
}

.action-title {
  color: #2a4034;
  font-size: 14.5px;
  font-weight: 600;
}

.action-detail {
  margin-top: 6rpx;
  color: #6a776f;
  font-size: 14px;
}

.selection-hint {
  margin-top: 18rpx;
  color: #72514d;
  font-size: 14px;
}

.confirm-button,
.debrief-button {
  min-height: 90rpx;
  margin-top: 24rpx;
  border-radius: 18rpx;
  background: #167a43;
  color: #ffffff;
  font-size: 16px;
  font-weight: 700;
  line-height: 90rpx;
}

.help-card {
  border: 2rpx solid #f0d6d2;
}

.help-disclaimer {
  margin-top: 14rpx;
  color: #72514d;
  font-size: 16px;
  line-height: 1.65;
}

.help-input,
.debrief-input,
.text-input,
.picker-field {
  box-sizing: border-box;
  width: 100%;
  margin-top: 16rpx;
  padding: 20rpx 22rpx;
  border: 2rpx solid #ced9d2;
  border-radius: 16rpx;
  background: #ffffff;
  color: #24362c;
  font-size: 14px;
}

.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
}

.picker-icon {
  flex: 0 0 auto;
  width: 36rpx;
  height: 36rpx;
  opacity: 0.62;
}

.help-input,
.debrief-input {
  min-height: 120rpx;
}

.help-input {
  font-size: 16px;
  line-height: 1.55;
}

.help-buttons {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.help-button,
.emergency-button {
  flex: 1;
  min-height: 88rpx;
  margin: 0;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  font-size: 16px;
  line-height: 1.4;
}

.help-button {
  background: #b42318;
  color: #ffffff;
}

.emergency-button {
  border: 1rpx solid #d7aaa5;
  background: #ffffff;
  color: #9b2c24;
}

.field-label {
  margin-top: 22rpx;
  color: #354a3e;
  font-size: 14px;
  font-weight: 600;
}

.field-label.spaced {
  margin-top: 24rpx;
}

.picker-field,
.text-input {
  min-height: 88rpx;
}

.optin-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 88rpx;
  margin-top: 24rpx;
  color: #52645a;
  font-size: 14px;
}

.medical-note {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #fff9ed;
  color: #6f5b35;
  font-size: 16px;
  line-height: 1.65;
}

@media screen and (max-width: 340px) {
  .help-buttons {
    flex-direction: column;
  }

  .help-button,
  .emergency-button {
    width: 100%;
  }
}
