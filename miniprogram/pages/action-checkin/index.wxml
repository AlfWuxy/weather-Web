<view class="page-shell">
  <view class="page-title">{{elderName}}的今日行动</view>
  <view class="page-copy">根据都昌县共享天气快照列出简单行动。勾选实际做过的事项，再保存记录。</view>

  <view wx:if="{{loading}}" class="state-box" role="status" aria-role="status">正在核对家人信息并加载今日清单…</view>
  <view wx:elif="{{loadError}}" class="state-box error-state" role="alert" aria-role="alert">
    <view class="state-title">暂时无法加载今日行动</view>
    <view class="state-copy">{{loadError}}</view>
    <button class="retry-button" bindtap="loadContext">重新加载家人信息</button>
  </view>
  <block wx:elif="{{contextReady}}">
    <view class="weather-card {{!weather.available ? 'pending' : weather.stale ? 'stale' : (weather.trigger || 'normal')}}">
      <view class="weather-title">都昌县 · {{weatherStatus}}</view>
      <view class="weather-detail" wx:if="{{weather.available && weather.stale}}">正在显示较早天气。当前使用通用安全行动，请刷新后再判断今日风险。</view>
      <view class="weather-detail" wx:elif="{{weather.available}}">最高 {{weather.temperatureMax === null ? '--' : weather.temperatureMax}}° · 最低 {{weather.temperatureMin === null ? '--' : weather.temperatureMin}}°</view>
      <view class="weather-detail" wx:else>天气数据待更新，当前显示通用安全行动，可稍后重试刷新。</view>
    </view>

    <view class="action-card">
      <view class="section-title">今天做到哪些？</view>
      <checkbox-group bindchange="onActionsChange">
        <label wx:for="{{actions}}" wx:key="id" class="action-row">
          <checkbox value="{{item.id}}" checked="{{item.checked}}" disabled="{{!contextReady}}" color="#167a43" aria-checked="{{item.checked}}" aria-label="{{item.title}}，{{item.detail}}" />
          <view class="action-copy">
            <view class="action-title">{{item.title}}</view>
            <view class="action-detail">{{item.detail}}</view>
          </view>
        </label>
      </checkbox-group>
      <view wx:if="{{confirmed}}" class="selection-hint" role="status" aria-role="status">已恢复今天保存的行动，可调整后再次保存。</view>
      <view wx:elif="{{!selectedActions.length}}" class="selection-hint" role="status" aria-role="status">请至少勾选一项实际完成的行动。</view>
      <button class="confirm-button" loading="{{busyAction === 'confirm'}}" disabled="{{!contextReady || busyAction !== '' || !selectedActions.length}}" bindtap="confirmActions">{{confirmed ? '今日行动已记录' : '保存已完成行动'}}</button>
    </view>

    <view class="help-card">
      <view class="section-title danger-title">需要家人帮助？</view>
      <view class="help-disclaimer">这里仅保存求助需求，不会自动通知照护人。请同时通过电话或微信直接联系家人，紧急时拨打 120。</view>
      <textarea class="help-input" maxlength="300" value="{{helpNote}}" disabled="{{!contextReady || busyAction !== ''}}" bindinput="onHelpNote" placeholder="可简单说明需要什么帮助，请勿填写身份证号" aria-label="需要家人帮助的内容" />
      <view class="help-buttons">
        <button class="help-button" loading="{{busyAction === 'help'}}" disabled="{{!contextReady || busyAction !== ''}}" bindtap="requestHelp">{{helpRecorded ? '更新求助说明' : '记录求助需求'}}</button>
        <button class="emergency-button" bindtap="callEmergency">紧急时拨打 120</button>
      </view>
    </view>

    <view class="debrief-card">
      <view class="section-title">简单复盘</view>
      <view class="field-label">今天完成得怎么样？</view>
      <picker range="{{completionOptions}}" value="{{completionIndex}}" disabled="{{!contextReady || busyAction !== ''}}" bindchange="onCompletionChange" aria-label="今天的行动完成情况">
        <view class="picker-field"><text>{{question1}}</text><image class="picker-icon" src="/assets/icons/chevron-right.png" mode="aspectFit" aria-hidden="true" /></view>
      </picker>
      <view class="field-label spaced">哪一项最容易做到？</view>
      <input class="text-input" maxlength="200" value="{{question2}}" disabled="{{!contextReady || busyAction !== ''}}" bindinput="onQuestion2" placeholder="例如：先喝一杯水" aria-label="复盘：哪一项最容易做到" />
      <view class="field-label spaced">下次希望家人怎么帮？</view>
      <input class="text-input" maxlength="200" value="{{question3}}" disabled="{{!contextReady || busyAction !== ''}}" bindinput="onQuestion3" placeholder="例如：中午打电话提醒" aria-label="复盘：下次希望家人怎么帮" />
      <view class="field-label spaced">还有什么困难？</view>
      <textarea class="debrief-input" maxlength="500" value="{{difficulty}}" disabled="{{!contextReady || busyAction !== ''}}" bindinput="onDifficulty" placeholder="可选填" aria-label="复盘：还有什么困难" />
      <label class="optin-row" for="debriefOptinSwitch" aria-label="关联到这位家人的今日记录">
        <switch id="debriefOptinSwitch" checked="{{debriefOptin}}" disabled="{{!contextReady || busyAction !== ''}}" color="#167a43" bindchange="onDebriefOptin" aria-checked="{{debriefOptin}}" aria-label="关联到这位家人的今日记录" />
        <view>关联到这位家人的今日记录</view>
      </label>
      <view class="selection-hint">关闭后不会显示在这位家人的今日记录中。复盘仍随你的账号保存，并在账号注销时删除；无论是否关联，都计入当天社区复盘提交数量，社区页只展示提交数量，不展示复盘原文。</view>
      <button class="debrief-button" loading="{{busyAction === 'debrief'}}" disabled="{{!contextReady || busyAction !== ''}}" bindtap="submitDebrief">保存复盘</button>
    </view>
  </block>
  <view wx:else class="state-box">请先返回家人列表，选择需要记录的家人。</view>

  <view class="medical-note">本页是行动筛查与记录，不作医疗诊断或治疗建议。严重或持续不适时，请及时就医或求助。</view>
</view>
