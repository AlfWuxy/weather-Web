<view class="page-shell">
  <view class="welcome-card">
    <view class="brand-mark"><image src="/assets/icons/sunny.png" mode="aspectFit" aria-hidden="true" /></view>
    <view class="welcome-title">宜老天气通</view>
    <view class="welcome-subtitle">都昌县天气预警与家庭照护</view>
  </view>

  <view class="card login-card motion-enter">
    <view class="section-title">登录后管理家人</view>
    <view class="section-copy">优先使用微信快捷登录。系统只读取登录所需的临时凭证，不读取你的聊天、通讯录或位置。</view>

    <view class="consent-row" role="group" aria-role="group" aria-label="登录协议确认区">
      <label class="consent-check" for="privacyAgreementCheckbox" aria-label="勾选表示已阅读并同意隐私说明和用户协议">
        <checkbox-group class="consent-check-group" bindchange="onConsentChange" role="group" aria-role="group" aria-label="隐私说明和用户协议确认">
          <checkbox id="privacyAgreementCheckbox" value="agreed" checked="{{privacyAgreed}}" color="#b64815" aria-label="勾选表示已阅读并同意隐私说明和用户协议" />
        </checkbox-group>
        <view class="consent-copy">我已阅读并同意</view>
      </label>
      <view class="consent-body">
        <button class="privacy-link" catchtap="openPrivacy" aria-label="阅读隐私说明">《隐私说明》</button>
        <view class="consent-tail">
          <view class="consent-copy">和</view>
          <button class="privacy-link" catchtap="openAgreement" aria-label="阅读用户协议">《用户协议》</button>
        </view>
      </view>
    </view>

    <button class="wechat-button" loading="{{busy}}" disabled="{{busy}}" bindtap="onWechatLogin" hover-class="button-pressed" aria-label="微信快捷登录">微信快捷登录</button>
    <view wx:if="{{loginHint}}" class="status-hint" role="status" aria-role="status" aria-live="polite">{{loginHint}}</view>

    <button class="fallback-link" bindtap="toggleTokenFallback" hover-class="button-pressed">
      {{showTokenFallback ? '收起备用登录码' : '使用备用登录码'}}
    </button>

    <view wx:if="{{showTokenFallback}}" class="fallback-panel">
      <view class="field-label">备用登录码</view>
      <input
        class="text-input"
        password="true"
        maxlength="512"
        placeholder="粘贴网页端生成的登录码"
        value="{{tokenInput}}"
        bindinput="onTokenInput"
        aria-label="备用登录码"
      />
      <view class="button-row">
        <button class="primary-button row-button" loading="{{busy}}" disabled="{{busy}}" bindtap="onBind" hover-class="button-pressed">验证并进入</button>
        <button class="secondary-button row-button" disabled="{{busy}}" bindtap="onClear" hover-class="button-pressed">清空输入</button>
      </view>
      <view class="security-note">登录码只用于验证本服务账号，不会显示在页面中。请勿转发给他人。</view>
    </view>
  </view>

  <view class="public-note">无需登录也可以从小程序首页查看都昌县公共天气和预警。</view>
  <button class="public-home-button" bindtap="goPublicHome" hover-class="button-pressed">先查看公共天气</button>
</view>
