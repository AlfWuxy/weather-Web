.page-shell {
  padding: 40rpx 28rpx calc(64rpx + env(safe-area-inset-bottom));
}

.welcome-card {
  padding: 28rpx 12rpx 36rpx;
  text-align: center;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 20rpx;
  border-radius: 30rpx;
  background: #f9d9be;
  box-shadow: 0 12rpx 28rpx rgba(182, 72, 21, 0.16);
}

.brand-mark image {
  width: 54rpx;
  height: 54rpx;
  opacity: 0.72;
}

.welcome-title {
  color: #2f2925;
  font-size: 44rpx;
  font-weight: 700;
}

.welcome-subtitle {
  margin-top: 10rpx;
  color: #786d65;
  font-size: 14px;
}

.login-card {
  padding: 32rpx;
}

.section-title {
  color: #2f2925;
  font-size: 36rpx;
  font-weight: 700;
}

.section-copy {
  margin-top: 14rpx;
  color: #66594f;
  font-size: 14px;
  line-height: 1.7;
}

.consent-row {
  display: flex;
  align-items: flex-start;
  margin: 28rpx 0;
  min-height: 88rpx;
}

.consent-check {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: flex-start;
  min-width: 88rpx;
  min-height: 88rpx;
}

.consent-check-group {
  display: flex;
  flex: 0 0 88rpx;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  min-height: 88rpx;
}

.consent-body {
  display: flex;
  flex: 1;
  flex-wrap: wrap;
  align-items: center;
  min-width: 0;
  line-height: 1.7;
}

.consent-tail {
  display: inline-flex;
  flex: 0 0 auto;
  align-items: center;
  min-height: 88rpx;
}

.consent-copy,
.privacy-link {
  font-size: 14px;
}

.consent-copy {
  color: #36463d;
}

.privacy-link {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  margin: 0;
  padding: 0 8rpx;
  color: #8d3511;
  background: transparent;
  font-weight: 600;
  line-height: 1.7;
}

.privacy-link::after { border: 0; }

.wechat-button {
  width: 100%;
  min-width: 100%;
  min-height: 96rpx;
  border-radius: 20rpx;
  background: #b64815;
  color: #ffffff;
  font-size: 16px;
  font-weight: 700;
  line-height: 96rpx;
}

.fallback-link {
  margin-top: 18rpx;
  background: transparent;
  color: #8d3511;
  font-size: 14px;
}

.fallback-link::after {
  border: 0;
}

.fallback-panel {
  margin-top: 20rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #e2e9e5;
}

.field-label {
  margin-bottom: 12rpx;
  color: #32433a;
  font-size: 14px;
  font-weight: 600;
}

.text-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 88rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #ced9d2;
  border-radius: 16rpx;
  background: #ffffff;
  font-size: 14px;
}

.button-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.row-button {
  flex: 1;
  min-height: 88rpx;
  font-size: 14px;
  line-height: 88rpx;
}

.security-note,
.status-hint,
.public-note {
  color: #69776f;
  font-size: 14px;
  line-height: 1.6;
}

.security-note,
.status-hint {
  margin-top: 16rpx;
}

.status-hint {
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  background: #f3f8f5;
  color: #345b45;
}

.public-note {
  padding: 28rpx 20rpx 0;
  text-align: center;
}

.public-home-button {
  margin-top: 12rpx;
  background: transparent;
  color: #8d3511;
  font-size: 14px;
  font-weight: 600;
}

.public-home-button::after {
  border: 0;
}

@media screen and (max-width: 340px) {
  .consent-check-group { flex-basis: 44px; width: 44px; }
  .button-row { flex-direction: column; }
  .row-button { width: 100%; }
}
