.today-card { margin-top: 20rpx; padding: 32rpx; }
.temperature { margin-top: 8rpx; color: #b64815; font-size: 94rpx; line-height: 1; font-weight: 850; }
.condition { margin-top: 12rpx; font-size: 32rpx; font-weight: 700; }
.risk-bubble { display: flex; flex: 0 0 176rpx; align-items: center; justify-content: center; min-height: 150rpx; padding: 20rpx; border-radius: 28rpx; text-align: center; flex-direction: column; }
.risk-label { font-size: 27rpx; font-weight: 750; }
.risk-score { margin-top: 4rpx; font-size: 48rpx; line-height: 1.1; font-weight: 850; }
.weather-details { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; margin-top: 28rpx; padding-top: 24rpx; border-top: 1rpx solid #efe2d8; }
.weather-details > view { display: flex; align-items: center; gap: 8rpx; flex-direction: column; }
.detail-value { font-size: 31rpx; font-weight: 750; }
.risk-summary { margin-top: 24rpx; padding: 20rpx; border-radius: 18rpx; color: #6a4c3a; background: #fff2e3; font-size: 27rpx; line-height: 1.6; }
.quick-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18rpx; margin-top: 20rpx; }
.quick-card { min-height: 180rpx; padding: 24rpx; border: 1rpx solid #f0ded0; border-radius: 24rpx; background: #fffdf9; }
.quick-icon { display: flex; align-items: center; justify-content: center; width: 58rpx; height: 58rpx; margin-bottom: 16rpx; border-radius: 17rpx; color: #a34216; background: #fff0dc; font-size: 32rpx; font-weight: 800; }
.action-line { display: flex; align-items: flex-start; gap: 20rpx; }
.action-number { display: flex; flex: 0 0 52rpx; align-items: center; justify-content: center; width: 52rpx; height: 52rpx; border-radius: 50%; color: #fff; background: #d85d19; font-size: 25rpx; font-weight: 800; }
.action-copy { flex: 1; min-width: 0; }
.action-detail { margin-top: 8rpx; }
.home-note { margin-top: 34rpx; }
