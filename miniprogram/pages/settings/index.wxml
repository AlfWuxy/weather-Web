<view class="page-shell">
  <view class="page-title">照护设置</view>
  <view class="page-copy">都昌县天气统一按 30 分钟共享快照更新，避免重复消耗天气接口额度。</view>

  <view class="policy-card">
    <view class="policy-icon">30</view>
    <view class="policy-main">
      <view class="policy-title">每 30 分钟自动更新</view>
      <view class="policy-copy">所有公共页面和老人卡片共用同一份都昌县快照。短时间重复打开不会再次请求上游天气 API。</view>
    </view>
  </view>

  <view wx:if="{{!loggedIn}}" class="guest-card">
    <view class="guest-title">登录开启家庭照护</view>
    <view class="guest-copy">登录后可添加老人、记录健康日记、保存用药记录和完成行动确认。查看公共天气、隐私说明和方法透明度无需登录。</view>
    <button class="login-button" bindtap="goLogin">微信登录或绑定 Token</button>
  </view>

  <view wx:if="{{loading}}" class="state-box">正在加载设置…</view>
  <block wx:elif="{{loggedIn}}">

    <view class="settings-card">
      <view class="section-title">网页端兼容推送</view>
      <view class="section-copy">如你仍在网页端使用 WxPusher，可保留原有 UID。微信小程序通知权限由系统设置管理。</view>
      <view class="field-label">WxPusher UID</view>
      <input class="text-input" maxlength="80" value="{{wxpusherUid}}" bindinput="onUid" placeholder="例如：UID_xxxxx" />
      <view class="switch-row">
        <view>
          <view class="switch-title">开启兼容推送</view>
          <view class="switch-copy">UID 为空时不会开启</view>
        </view>
        <switch checked="{{pushEnabled}}" color="#168a4a" bindchange="onToggle" />
      </view>
      <button class="save-button" loading="{{busy}}" disabled="{{busy}}" bindtap="saveSettings">保存推送设置</button>
    </view>

  </block>

  <view class="menu-card">
    <button class="menu-row" bindtap="goPrivacy">
      <view>
        <view class="menu-title">隐私说明</view>
        <view class="menu-copy">无需登录即可查看数据收集与使用边界</view>
      </view>
      <view class="chevron">›</view>
    </button>
    <button class="menu-row border-top" bindtap="goTransparency">
      <view>
        <view class="menu-title">计算透明度</view>
        <view class="menu-copy">查看数据来源、计算方法和适用边界</view>
      </view>
      <view class="chevron">›</view>
    </button>
    <button class="menu-row border-top" bindtap="goAbout">
      <view>
        <view class="menu-title">关于宜老天气通</view>
        <view class="menu-copy">了解产品目标与信任网络</view>
      </view>
      <view class="chevron">›</view>
    </button>
    <button wx:if="{{loggedIn}}" class="menu-row border-top" bindtap="openSystemSettings">
      <view>
        <view class="menu-title">微信通知权限</view>
        <view class="menu-copy">查看小程序通知和系统权限</view>
      </view>
      <view class="chevron">›</view>
    </button>
    <button wx:if="{{loggedIn}}" class="menu-row border-top" bindtap="goAccount">
        <view>
          <view class="menu-title">账号、隐私与注销</view>
          <view class="menu-copy">管理登录状态或申请注销账号</view>
        </view>
        <view class="chevron">›</view>
    </button>
  </view>

  <button wx:if="{{loggedIn}}" class="logout-button" loading="{{busy}}" disabled="{{busy}}" bindtap="logout">退出登录</button>
</view>
