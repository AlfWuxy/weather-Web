<view class="page-shell">
  <view class="page-title">照护设置</view>
  <view class="page-copy">都昌县天气统一按 30 分钟共享快照更新，避免重复消耗天气接口额度。</view>

  <view class="policy-card">
    <view class="policy-icon">30</view>
    <view class="policy-main">
      <view class="policy-title">每 30 分钟自动更新</view>
      <view class="policy-copy">所有公共页面和老人卡片共用同一份都昌县快照。短时间重复打开不会再次请求上游天气 API。</view>
    </view>
  </view>

  <view wx:if="{{!loggedIn}}" class="guest-card">
    <view class="guest-title">登录开启家庭照护</view>
    <view class="guest-copy">登录后可添加家人、保存每日照护记录、完成行动确认和设置提醒。查看公共天气、隐私说明和方法透明度无需登录。</view>
    <button class="login-button" bindtap="goLogin" hover-class="button-pressed">微信登录</button>
    <view class="fallback-note">微信登录暂不可用时，登录页也提供备用登录码。</view>
  </view>

  <view wx:if="{{loading}}" class="state-box">正在加载设置…</view>
  <block wx:elif="{{loggedIn}}">

    <view class="settings-card">
      <view class="section-title">网页端兼容推送</view>
      <view class="section-copy">这是独立于微信系统通知的可选第三方通道，默认关闭。开启前请确认下方传输范围。</view>
      <view class="field-label">WxPusher UID</view>
      <input class="text-input" maxlength="80" value="{{wxpusherUid}}" bindinput="onUid" placeholder="例如：UID_xxxxx" aria-label="WxPusher UID" />
      <label class="switch-row" for="wxpusherSwitch" aria-label="开启网页端兼容推送">
        <view>
          <view class="switch-title">开启兼容推送</view>
          <view class="switch-copy">UID 为空时不会开启</view>
        </view>
        <switch id="wxpusherSwitch" checked="{{pushEnabled}}" color="#137947" bindchange="onToggle" aria-label="开启网页端兼容推送" />
      </label>
      <label wx:if="{{pushEnabled}}" class="third-party-consent">
        <checkbox-group bindchange="onWxPusherConsent">
          <checkbox value="agreed" checked="{{wxpusherConsent}}" color="#137947" aria-label="同意 WxPusher 第三方传输说明" />
        </checkbox-group>
        <view class="consent-copy">我同意向 WxPusher 发送 UID、都昌县级预警标题与正文及一次性点击链接。不会发送家人姓名、健康日记、用药记录或家庭地址。</view>
      </label>
      <button class="save-button" loading="{{busy}}" disabled="{{busy}}" bindtap="saveSettings" hover-class="button-pressed">保存推送设置</button>
    </view>

  </block>

  <view class="menu-card">
    <button class="menu-row" bindtap="goPrivacy" hover-class="button-pressed">
      <view>
        <view class="menu-title">隐私说明</view>
        <view class="menu-copy">无需登录即可查看数据收集与使用边界</view>
      </view>
      <image class="chevron" src="/assets/icons/chevron-right.png" mode="aspectFit" aria-hidden="true" />
    </button>
    <button class="menu-row border-top" bindtap="goTransparency" hover-class="button-pressed">
      <view>
        <view class="menu-title">计算透明度</view>
        <view class="menu-copy">查看数据来源、计算方法和适用边界</view>
      </view>
      <image class="chevron" src="/assets/icons/chevron-right.png" mode="aspectFit" aria-hidden="true" />
    </button>
    <button class="menu-row border-top" bindtap="goAgreement" hover-class="button-pressed">
      <view>
        <view class="menu-title">用户协议</view>
        <view class="menu-copy">查看服务范围、使用规则和责任边界</view>
      </view>
      <image class="chevron" src="/assets/icons/chevron-right.png" mode="aspectFit" aria-hidden="true" />
    </button>
    <button class="menu-row border-top" bindtap="goAbout" hover-class="button-pressed">
      <view>
        <view class="menu-title">关于宜老天气通</view>
        <view class="menu-copy">了解产品目标与信任网络</view>
      </view>
      <image class="chevron" src="/assets/icons/chevron-right.png" mode="aspectFit" aria-hidden="true" />
    </button>
    <button wx:if="{{loggedIn}}" class="menu-row border-top" bindtap="openSystemSettings" hover-class="button-pressed">
      <view>
        <view class="menu-title">微信通知权限</view>
        <view class="menu-copy">查看小程序通知和系统权限</view>
      </view>
      <image class="chevron" src="/assets/icons/chevron-right.png" mode="aspectFit" aria-hidden="true" />
    </button>
    <button wx:if="{{loggedIn}}" class="menu-row border-top" bindtap="goAccount" hover-class="button-pressed">
        <view>
          <view class="menu-title">账号、隐私与注销</view>
          <view class="menu-copy">管理登录状态或申请注销账号</view>
        </view>
        <image class="chevron" src="/assets/icons/chevron-right.png" mode="aspectFit" aria-hidden="true" />
    </button>
  </view>

  <button wx:if="{{loggedIn}}" class="logout-button" loading="{{busy}}" disabled="{{busy}}" bindtap="logout" hover-class="button-pressed">退出登录</button>
</view>
