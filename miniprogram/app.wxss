page {
  min-height: 100%;
  background: #fff8f0;
  color: #2f2925;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 16px;
}

@keyframes rise-in {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

view, text, button, navigator, picker, input, textarea, label, scroll-view, canvas {
  box-sizing: border-box;
}

button,
navigator,
picker,
input,
textarea,
label {
  min-height: 88rpx;
}

button,
input,
textarea {
  font-size: 16px;
}

button {
  line-height: 1.4;
}

button,
navigator {
  transition: opacity 120ms ease-out, transform 120ms ease-out;
}

button::after {
  border: 0;
}

.page-shell {
  padding: 28rpx 28rpx calc(48rpx + env(safe-area-inset-bottom));
}

.hero {
  overflow: hidden;
  position: relative;
  padding: 30rpx;
  border-radius: 32rpx;
  color: #fff;
  background: linear-gradient(145deg, #9f3a12 0%, #b64815 100%);
  box-shadow: 0 18rpx 44rpx rgba(171, 69, 17, 0.2);
  animation: rise-in 220ms ease-out both;
}

.hero::after {
  content: "";
  position: absolute;
  right: -70rpx;
  top: -90rpx;
  width: 260rpx;
  height: 260rpx;
  border: 44rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 50%;
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #8a350f;
  background: #fff2df;
  font-size: 14px;
  font-weight: 700;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 800;
}

.hero-subtitle {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  color: #fff;
  background: #6f290d;
  font-size: 15px;
  line-height: 1.58;
}

.section-title {
  margin: 38rpx 4rpx 18rpx;
  font-size: 37rpx;
  line-height: 1.35;
  font-weight: 800;
}

.section-subtitle {
  margin: -8rpx 4rpx 18rpx;
  color: #786d65;
  font-size: 14px;
  line-height: 1.6;
}

.card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border: 1rpx solid #f0ded0;
  border-radius: 26rpx;
  background: #fffdf9;
  box-shadow: 0 10rpx 28rpx rgba(87, 54, 31, 0.07);
}

.motion-enter {
  animation: rise-in 200ms ease-out both;
}

.card-title {
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 750;
}

.muted {
  color: #786d65;
}

.small {
  font-size: 14px;
  line-height: 1.55;
}

.strong {
  font-weight: 750;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.wrap {
  flex-wrap: wrap;
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.metric {
  padding: 24rpx;
  border-radius: 22rpx;
  background: #fff1df;
}

.metric-label {
  color: #7a6558;
  font-size: 14px;
}

.metric-value {
  margin-top: 8rpx;
  color: #9e3e12;
  font-size: 40rpx;
  font-weight: 800;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 7rpx 17rpx;
  border-radius: 999rpx;
  color: #6e5443;
  background: #f8eadf;
  font-size: 14px;
  font-weight: 650;
}

.pill.low, .risk-low {
  color: #226744;
  background: #e6f6ed;
}

.pill.mid, .risk-mid {
  color: #845d00;
  background: #fff3cf;
}

.pill.high, .risk-high {
  color: #a0281a;
  background: #ffe6df;
}

.pill.unknown, .risk-unknown {
  color: #645f5b;
  background: #eeeae6;
}

.primary-button, .secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  padding: 20rpx 26rpx;
  border-radius: 20rpx;
  font-weight: 750;
  transition: opacity 150ms ease, transform 150ms ease;
}

.primary-button {
  color: #fff;
  background: #b64815;
}

.secondary-button {
  color: #8d3511;
  background: #fff1df;
  border: 1rpx solid #efc7a9;
}

.link-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 118rpx;
  padding: 22rpx;
  border: 1rpx solid #f0ded0;
  border-radius: 24rpx;
  color: #332a25;
  background: #fffdf9;
  transition: opacity 150ms ease, transform 150ms ease;
}

.link-icon {
  display: flex;
  flex: 0 0 72rpx;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #fff0dc;
}

.link-icon-image,
.inline-icon,
.button-icon {
  width: 38rpx;
  height: 38rpx;
  opacity: 0.72;
}

.button-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
}

.button-pressed {
  opacity: 0.88;
  transform: scale(0.99);
}

.menu-row.button-pressed {
  opacity: 1;
  transform: none;
  background: #f3f8f5;
}

.divider {
  height: 1rpx;
  margin: 22rpx 0;
  background: #efe2d8;
}

.safe-note {
  padding: 22rpx 24rpx;
  border-left: 8rpx solid #e7762e;
  border-radius: 18rpx;
  color: #654d3e;
  background: #fff0df;
  font-size: 14px;
  line-height: 1.65;
}

.empty-space {
  height: 18rpx;
}

@media (prefers-reduced-motion: reduce) {
  .hero,
  .motion-enter {
    animation: none;
  }

  button,
  navigator,
  .primary-button,
  .secondary-button,
  .link-card,
  .hero-share,
  .quick-card {
    transition: none;
  }

  .button-pressed {
    transform: none;
  }
}

@media screen and (max-width: 374px) {
  button,
  navigator,
  picker,
  input,
  textarea,
  label,
  switch,
  checkbox,
  radio,
  checkbox-group,
  radio-group {
    min-height: 44px !important;
  }

  switch,
  checkbox,
  radio,
  checkbox-group,
  radio-group {
    min-width: 44px !important;
  }

  .grid-two { grid-template-columns: 1fr; }
  .row-between { flex-wrap: wrap; }
}
