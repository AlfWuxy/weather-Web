<view style="padding: 16px;">
  <view class="card">
    <view style="font-size: 18px; font-weight: 700;">推送设置（试点）</view>
    <view class="muted" style="margin-top: 6px; font-size: 12px;">
      试点阶段使用 WxPusher 推送。填写 UID 后可开启自动推送。
    </view>

    <view style="margin-top: 14px;">
      <view class="muted" style="font-size: 12px;">WxPusher UID</view>
      <input value="{{wxpusherUid}}" bindinput="onUid" placeholder="例如：UID_xxxxx" style="border: 1px solid #e5e7eb; border-radius: 10px; padding: 10px 12px; background:#fff;" />
    </view>

    <view style="margin-top: 10px; display:flex; align-items:center; gap: 10px;">
      <switch checked="{{pushEnabled}}" bindchange="onToggle" />
      <view>开启自动推送</view>
    </view>

    <view style="display:flex; gap: 10px; margin-top: 14px;">
      <button class="btn-primary" style="flex:1;" bindtap="onSave">保存</button>
      <button class="btn-outline" style="flex:1;" bindtap="logout">退出绑定</button>
    </view>
  </view>
</view>

